# ============================================================
#  vix_regime_backtest.py
#  VIX Regime Strategy vs Buy & Hold — 30-Year Backtest
#  Outputs a single self-contained HTML dashboard (no JSON needed)
#  Run: python vix_regime_backtest.py  → open output_dashboard.html
# ============================================================

import json
import numpy as np
import pandas as pd
import yfinance as yf
from scipy.optimize import brentq
from datetime import datetime

# ── Parameters ────────────────────────────────────────────────────────────────
START_DATE     = "1994-01-01"
END_DATE       = datetime.today().strftime("%Y-%m-%d")
MONTHLY_INVEST = 100.0
DCA_FRAC       = 0.95
TACTICAL_FRAC  = 0.05
VIX_LOW        = 15
VIX_HIGH       = 28
OUTPUT_HTML    = "output_dashboard.html"

# ── 1. Download ───────────────────────────────────────────────────────────────
print("Downloading SPX and VIX data...")

def download_close(ticker):
    raw = yf.download(ticker, start=START_DATE, end=END_DATE,
                      auto_adjust=True, progress=False)
    if isinstance(raw.columns, pd.MultiIndex):
        raw.columns = raw.columns.droplevel(1)
    s = raw["Close"].squeeze()
    s.index = pd.to_datetime(s.index)
    return s

spx = download_close("^GSPC"); spx.name = "SPX"
vix = download_close("^VIX");  vix.name = "VIX"
df  = pd.DataFrame({"SPX": spx, "VIX": vix}).dropna()
df.index = pd.to_datetime(df.index)

# ── 2. Regimes ────────────────────────────────────────────────────────────────
def label_regime(v):
    if v < VIX_LOW:   return "low"
    elif v < VIX_HIGH: return "medium"
    else:              return "high"

df["regime"] = df["VIX"].apply(label_regime)

# ── 3. First trading day of each month ───────────────────────────────────────
df["ym"] = df.index.to_period("M")
first_trading_days = set(df.groupby("ym").apply(lambda g: g.index.min()).values)

# ── 4. Simulation ─────────────────────────────────────────────────────────────
baseline_shares = 0.0
strategy_shares = 0.0
tactical_cash   = 0.0
baseline_cf     = []
strategy_cf     = []
baseline_tl     = []
strategy_tl     = []

for date in df.index:
    row    = df.loc[date]
    price  = float(row["SPX"])
    regime = row["regime"]
    invest = date in first_trading_days

    if invest:
        # Baseline
        baseline_shares += MONTHLY_INVEST / price
        baseline_cf.append((date, -MONTHLY_INVEST))

        # Strategy — behaviour depends on regime
        if regime == "high":
            # VIX >= 28 on DCA day: invest full $100 + any accumulated reserve
            deploy = MONTHLY_INVEST + tactical_cash
            strategy_shares += deploy / price
            strategy_cf.append((date, -MONTHLY_INVEST))   # record the $100 outflow
            tactical_cash = 0.0                            # reserve fully deployed
        else:
            # Normal day: invest 95%, hold 5% in reserve
            strategy_shares += (MONTHLY_INVEST * DCA_FRAC) / price
            strategy_cf.append((date, -MONTHLY_INVEST * DCA_FRAC))
            tactical_cash += MONTHLY_INVEST * TACTICAL_FRAC
            strategy_cf.append((date, -MONTHLY_INVEST * TACTICAL_FRAC))

    baseline_tl.append((date.strftime("%Y-%m-%d"), baseline_shares * price))
    strategy_tl.append((date.strftime("%Y-%m-%d"), strategy_shares * price + tactical_cash))

# ── 5. Terminal values ────────────────────────────────────────────────────────
final_price    = float(df["SPX"].iloc[-1])
baseline_final = baseline_shares * final_price
strategy_final = strategy_shares * final_price + tactical_cash
total_invested = MONTHLY_INVEST * len(first_trading_days)

baseline_cf.append((df.index[-1], baseline_final))
strategy_cf.append((df.index[-1], strategy_final))

# ── 6. IRR ────────────────────────────────────────────────────────────────────
def compute_irr(cfs):
    dates   = [c[0] for c in cfs]
    amounts = [c[1] for c in cfs]
    t0      = dates[0]
    years   = [(d - t0).days / 365.25 for d in dates]
    def npv(r):
        return sum(a / (1+r)**t for a, t in zip(amounts, years))
    try:
        return brentq(npv, -0.999, 100.0, maxiter=1000)
    except:
        return float("nan")

print("Computing IRR...")
baseline_irr = compute_irr(baseline_cf)
strategy_irr = compute_irr(strategy_cf)

# ── 7. Drawdown ───────────────────────────────────────────────────────────────
def drawdown_series(vals):
    arr  = np.array(vals)
    peak = np.maximum.accumulate(arr)
    return ((arr - peak) / peak * 100).tolist()

def max_dd(vals):
    return min(drawdown_series(vals))

b_vals    = [v for _, v in baseline_tl]
s_vals    = [v for _, v in strategy_tl]
dates_str = [d for d, _ in baseline_tl]

b_mdd = max_dd(b_vals)
s_mdd = max_dd(s_vals)

# ── 8. Monthly sample for charts ─────────────────────────────────────────────
idx_series    = pd.Series(range(len(dates_str)), index=pd.DatetimeIndex(dates_str))
monthly_idx   = idx_series.resample("ME").last().dropna().astype(int).values

dates_m   = [dates_str[i]           for i in monthly_idx]
b_vals_m  = [round(b_vals[i], 2)    for i in monthly_idx]
s_vals_m  = [round(s_vals[i], 2)    for i in monthly_idx]
vix_m     = [round(float(df["VIX"].iloc[i]), 2) for i in monthly_idx]
b_dd_m    = [round(drawdown_series(b_vals)[i], 2) for i in monthly_idx]
s_dd_m    = [round(drawdown_series(s_vals)[i], 2) for i in monthly_idx]
regime_m  = [df["regime"].iloc[i]   for i in monthly_idx]

# ── 9. Regime distribution ────────────────────────────────────────────────────
reg_pct   = (df["regime"].value_counts(normalize=True) * 100).round(1).to_dict()
high_invest_days = sum(1 for d in first_trading_days if df.loc[d, "regime"] == "high")

# ── 10. Metrics ───────────────────────────────────────────────────────────────
b_ret = round((baseline_final / total_invested - 1) * 100, 2)
s_ret = round((strategy_final / total_invested - 1) * 100, 2)
b_irr = round(baseline_irr * 100, 4)
s_irr = round(strategy_irr * 100, 4)
b_mdd = round(b_mdd, 2)
s_mdd = round(s_mdd, 2)

irr_winner  = "strategy" if s_irr > b_irr else "baseline"
irr_delta   = round(abs(s_irr - b_irr), 4)
val_delta   = round(strategy_final - baseline_final, 2)
mdd_better  = s_mdd >= b_mdd   # less negative = better (higher number)

# ── 11. Print summary ─────────────────────────────────────────────────────────
print(f"\n{'='*58}")
print(f"  VIX REGIME STRATEGY — BACKTEST RESULTS")
print(f"{'='*58}")
print(f"  Period : {dates_str[0]} → {dates_str[-1]}")
print(f"  Months : {len(first_trading_days)}  |  Total invested: ${total_invested:,.0f}")
print(f"\n  {'Metric':<26} {'BASELINE':>10} {'STRATEGY':>10}")
print(f"  {'-'*48}")
print(f"  {'Final portfolio value':<26} ${baseline_final:>9,.0f} ${strategy_final:>9,.0f}")
print(f"  {'Total return':<26} {b_ret:>9.1f}% {s_ret:>9.1f}%")
print(f"  {'Annualised IRR ★':<26} {b_irr:>9.2f}% {s_irr:>9.2f}%")
print(f"  {'Max drawdown':<26} {b_mdd:>9.1f}% {s_mdd:>9.1f}%")
print(f"\n  ★ IRR WINNER: {irr_winner.upper()} (+{irr_delta:.4f}pp)")
print(f"  High-VIX invest days: {high_invest_days}")
print(f"  Tactical cash remaining: ${tactical_cash:,.2f}")
print(f"{'='*58}")

# ── 12. Build self-contained HTML ─────────────────────────────────────────────
