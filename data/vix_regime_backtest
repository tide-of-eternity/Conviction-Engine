// High-VIX band plugin
const bandPlugin = {{
  id:'band',
  beforeDraw(chart) {{
    const {{ ctx, chartArea:{{left,top,right,bottom}}, scales:{{x}} }} = chart;
    if (!x) return;
    ctx.save();
    D.chart.regime.forEach((r, i) => {{
      if (r !== 'high') return;
      const x0 = x.getPixelForValue(i);
