  type:'line', plugins:[bandPlugin],
  data:{ labels:D.chart.dates, datasets:[
    { label:'Baseline (B&H)', data:D.chart.bVals,
       borderColor:'#4f9cf9', backgroundColor:'rgba(79,156,249,.06)',
       borderWidth:2, pointRadius:0, fill:true, tension:0.2 },
    { label:'Strategy (95/5)', data:D.chart.sVals,
       borderColor:'#34d399', backgroundColor:'rgba(52,211,153,.06)',
       borderWidth:2, pointRadius:0, fill:true, tension:0.2 },
  ]},
  options: baseOpts(v => '$' + v.toLocaleString('en-US',{maximumFractionDigits:0}))
});

