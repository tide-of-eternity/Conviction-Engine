<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>VIX Regime Backtest Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');
:root{
  --bg:#0a0e1a;--surface:#111827;--surface2:#1a2235;--border:#1f2d45;
  --text:#e8edf5;--muted:#556070;
  --blue:#4f9cf9;--green:#34d399;--red:#f87171;--amber:#fbbf24;
  --low:#34d399;--med:#fbbf24;--high:#f87171;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Space Grotesk',sans-serif;padding:28px 24px;min-height:100vh}
/* ── header ── */
.header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px}
.header h1{font-size:18px;font-weight:700;letter-spacing:-.3px;font-family:'Space Mono',monospace}
.header h1 em{color:var(--amber);font-style:normal}
.period{font-family:'Space Mono',monospace;font-size:11px;color:var(--muted)}
/* ── winner banner ── */
.banner{border-radius:12px;padding:20px 28px;margin-bottom:24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.banner.strategy{background:linear-gradient(135deg,rgba(52,211,153,.12),rgba(52,211,153,.04));border:1px solid rgba(52,211,153,.3)}
.banner.baseline{background:linear-gradient(135deg,rgba(79,156,249,.12),rgba(79,156,249,.04));border:1px solid rgba(79,156,249,.3)}
.banner-icon{font-size:36px;line-height:1}
.banner-title{font-size:13px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.banner-val{font-family:'Space Mono',monospace;font-size:26px;font-weight:700}
.banner.strategy .banner-val{color:var(--green)}
.banner.baseline .banner-val{color:var(--blue)}
.banner-sub{font-size:13px;color:var(--muted);margin-top:3px}
.banner-delta{margin-left:auto;text-align:right}
.delta-pill{display:inline-block;padding:6px 14px;border-radius:20px;font-family:'Space Mono',monospace;font-size:13px;font-weight:700}
.strategy .delta-pill{background:rgba(52,211,153,.15);color:var(--green)}
.baseline .delta-pill{background:rgba(79,156,249,.15);color:var(--blue)}
/* ── metric grid ── */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:12px;margin-bottom:24px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 18px;position:relative;overflow:hidden}
.card-accent{position:absolute;top:0;left:0;right:0;height:3px;border-radius:10px 10px 0 0}
.card-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px}
.card-row{display:flex;gap:8px;align-items:flex-end}
.card-val{font-family:'Space Mono',monospace;font-size:18px;font-weight:700;flex:1}
.card-badge{font-family:'Space Mono',monospace;font-size:10px;padding:2px 7px;border-radius:4px;margin-bottom:2px;white-space:nowrap}
.badge-b{background:rgba(79,156,249,.15);color:var(--blue)}
.badge-s{background:rgba(52,211,153,.15);color:var(--green)}
.card-winner{position:absolute;top:10px;right:10px;font-size:14px}
/* ── charts ── */
.charts{display:flex;flex-direction:column;gap:16px}
.panel{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:20px 22px}
.panel-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px}
.panel-title{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
.legend{display:flex;gap:16px;flex-wrap:wrap}
.leg{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted)}
.leg-dot{width:10px;height:10px;border-radius:50%}
.chart-wrap{position:relative}
.chart-wrap canvas{width:100%!important}
/* ── regime bar ── */
.reg-bar{display:flex;height:28px;border-radius:6px;overflow:hidden;margin-bottom:8px}
.reg-seg{display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:10px;font-weight:700;transition:filter .2s}
.reg-seg:hover{filter:brightness(1.3)}
.seg-low{background:rgba(52,211,153,.25);color:var(--low)}
.seg-med{background:rgba(251,191,36,.25);color:var(--med)}
.seg-high{background:rgba(248,113,113,.25);color:var(--high)}
.reg-labels{display:flex;gap:18px;flex-wrap:wrap}
.reg-lbl{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:5px}
.reg-dot{width:8px;height:8px;border-radius:50%}
/* ── note ── */
.note{margin-top:20px;padding:14px 18px;background:rgba(79,156,249,.05);border:1px solid rgba(79,156,249,.12);border-radius:8px;font-size:12px;color:var(--muted);line-height:1.8}
</style>
</head>
<body>
<div class="header">
  <h1>VIX Regime Backtest <em>//</em> 30-Year Analysis</h1>
  <div class="period" id="periodLabel"></div>
</div>

<!-- IRR Winner Banner -->
<div class="banner" id="banner">
  <div class="banner-icon" id="bannerIcon"></div>
  <div>
    <div class="banner-title">IRR Winner — Annualised Return</div>
    <div class="banner-val" id="bannerVal"></div>
    <div class="banner-sub" id="bannerSub"></div>
  </div>
  <div class="banner-delta">
    <div style="font-size:12px;color:var(--muted);margin-bottom:6px">IRR advantage</div>
    <div class="delta-pill" id="bannerDelta"></div>
  </div>
</div>

<!-- Metric cards -->
<div class="grid" id="grid"></div>

<div class="charts">
  <!-- Portfolio value -->
  <div class="panel">
    <div class="panel-hd">
      <div class="panel-title">Cumulative Portfolio Value</div>
      <div class="legend">
        <div class="leg"><div class="leg-dot" style="background:var(--blue)"></div>Baseline (100% DCA)</div>
        <div class="leg"><div class="leg-dot" style="background:var(--green)"></div>Strategy (95/5 tactical)</div>
        <div class="leg"><div class="leg-dot" style="background:rgba(248,113,113,.4);border-radius:2px;width:14px;height:10px"></div>High VIX periods</div>
      </div>
    </div>
    <div class="chart-wrap" style="height:280px"><canvas id="cVal"></canvas></div>
  </div>

  <!-- Drawdown -->
  <div class="panel">
    <div class="panel-hd">
      <div class="panel-title">Drawdown from Peak (%)</div>
      <div class="legend">
        <div class="leg"><div class="leg-dot" style="background:var(--blue)"></div>Baseline</div>
        <div class="leg"><div class="leg-dot" style="background:var(--green)"></div>Strategy</div>
      </div>
    </div>
    <div class="chart-wrap" style="height:200px"><canvas id="cDD"></canvas></div>
  </div>

  <!-- VIX -->
  <div class="panel">
    <div class="panel-hd">
      <div class="panel-title">VIX Level over Time</div>
      <div class="legend">
        <div class="leg"><div class="leg-dot" style="background:rgba(52,211,153,.6);border-radius:2px;width:14px;height:2px"></div>Low &lt;15</div>
        <div class="leg"><div class="leg-dot" style="background:rgba(248,113,113,.6);border-radius:2px;width:14px;height:2px"></div>High ≥28 (deploy cash)</div>
      </div>
    </div>
    <div class="chart-wrap" style="height:200px"><canvas id="cVIX"></canvas></div>
  </div>

  <!-- Regime distribution -->
  <div class="panel">
    <div class="panel-hd"><div class="panel-title">Regime Distribution (% of trading days)</div></div>
    <div class="reg-bar" id="regBar"></div>
    <div class="reg-labels">
      <div class="reg-lbl"><div class="reg-dot" style="background:var(--low)"></div><span id="rLow"></span></div>
      <div class="reg-lbl"><div class="reg-dot" style="background:var(--med)"></div><span id="rMed"></span></div>
      <div class="reg-lbl"><div class="reg-dot" style="background:var(--high)"></div><span id="rHigh"></span></div>
    </div>
  </div>
</div>

<div class="note">
  <b>Assumptions:</b> $100/month on the first trading day of each month.
  <b>Baseline:</b> 100% into SPX (pure DCA).
  <b>Strategy:</b> $95 into SPX every month; $5 held as cash until VIX ≥ 28, then the full accumulated reserve is deployed into SPX (buy-and-hold once invested).
  No transaction costs. SPX index price only — no dividend reinvestment.
  IRR computed on exact dated cash flows, annualised via Brent's method.
</div>

