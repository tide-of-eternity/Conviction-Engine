  ['seg-low',  rp.low,    'Low'],
  ['seg-med',  rp.medium, 'Med'],
  ['seg-high', rp.high,   'High'],
].map(([cls, pct, lbl]) =>
  `<div class="reg-seg ${cls}" style="width:${pct}%" title="${lbl}: ${pct}%">${pct > 5 ? lbl + ' ' + pct + '%' : ''}</div>`
).join('');
