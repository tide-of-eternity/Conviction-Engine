       pointRadius:0, fill:false },
    { label:'High threshold (28)', data:Array(D.chart.dates.length).fill(28),
       borderColor:'rgba(248,113,113,.55)', borderDash:[5,4], borderWidth:1.2,
       pointRadius:0, fill:false },
  ]},
