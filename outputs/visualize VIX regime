Chart.defaults.color = '#556070';
Chart.defaults.font.family = "'Space Mono', monospace";
Chart.defaults.font.size   = 10;
const grid   = { color:'rgba(31,45,69,.8)' };
const xTicks = { maxTicksLimit:10, callback:(_,i) => D.chart.dates[i]?.slice(0,7) };
const tip    = callbacks => ({ mode:'index', intersect:false, plugins:{ tooltip:{ callbacks } } });

// High-VIX band plugin
const bandPlugin = {
  id:'band',
  beforeDraw(chart) {
    const { ctx, chartArea:{left,top,right,bottom}, scales:{x} } = chart;
    if (!x) return;
    ctx.save();
    D.chart.regime.forEach((r, i) => {
      if (r !== 'high') return;
      const x0 = x.getPixelForValue(i);
      const x1 = x.getPixelForValue(i+1) || right;
      ctx.fillStyle = 'rgba(248,113,113,0.07)';
      ctx.fillRect(x0, top, x1-x0, bottom-top);
    });
    ctx.restore();
  }
};

const baseOpts = (yFmt) => ({
  responsive:true, maintainAspectRatio:false,
  interaction:{ mode:'index', intersect:false },
  plugins:{ legend:{ display:false }, tooltip:{ callbacks:{ label: ctx => ' ' + ctx.dataset.label + ': ' + yFmt(ctx.raw) } } },
  scales:{
    x:{ grid, ticks:xTicks },
    y:{ grid, ticks:{ maxTicksLimit:6, callback:yFmt } }
  }
});

// 1. Portfolio value
