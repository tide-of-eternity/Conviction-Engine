// ── helpers ──────────────────────────────────────────────────────────────────
const $  = id => document.getElementById(id);
const fmt$ = v => '$' + v.toLocaleString('en-US', {maximumFractionDigits:0});
const fmtP = (v, d=2) => v.toFixed(d) + '%';

// ── banner ───────────────────────────────────────────────────────────────────
const wb   = D.winner === 'strategy';
const winS = wb ? D.summary.strategy : D.summary.baseline;
const losS = wb ? D.summary.baseline : D.summary.strategy;
$('banner').classList.add(D.winner);
$('bannerIcon').textContent = wb ? '🏆' : '📊';
$('bannerVal').textContent  = fmtP(winS.irr) + ' IRR  (' + (wb ? 'Strategy' : 'Baseline') + ')';
$('bannerSub').textContent  = 'vs ' + fmtP(losS.irr) + ' for the ' + (wb ? 'baseline' : 'strategy');
$('bannerDelta').textContent = '+' + D.irrDelta.toFixed(4) + ' pp';
$('periodLabel').textContent = D.meta.start + ' → ' + D.meta.end + '  |  ' + D.meta.months + ' months  |  $' + D.meta.totalInvested.toLocaleString() + ' invested';

// ── metric cards ─────────────────────────────────────────────────────────────
const b = D.summary.baseline, s = D.summary.strategy;
const irrWinB = b.irr >= s.irr, mddWinS = s.mdd >= b.mdd;

const cards = [
  { label:'Annualised IRR', bVal: fmtP(b.irr), sVal: fmtP(s.irr), bColor:'var(--blue)', sColor:'var(--green)', winnerB: irrWinB, key:'irr' },
  { label:'Final Portfolio Value', bVal: fmt$(b.finalVal), sVal: fmt$(s.finalVal), bColor:'var(--blue)', sColor:'var(--green)', winnerB: b.finalVal >= s.finalVal, key:'val' },
  { label:'Total Return', bVal: fmtP(b.totalRet,1), sVal: fmtP(s.totalRet,1), bColor:'var(--blue)', sColor:'var(--green)', winnerB: b.totalRet >= s.totalRet, key:'ret' },
  { label:'Max Drawdown', bVal: fmtP(b.mdd,1), sVal: fmtP(s.mdd,1), bColor:'var(--blue)', sColor:'var(--green)', winnerB: !mddWinS, note:'(less negative = better)', key:'mdd' },
  { label:'High-VIX Deploy Days', bVal: '—', sVal: s.highDays + ' days', bColor:'var(--blue)', sColor:'var(--amber)', winnerB: false, key:'hd' },
  { label:'Tactical Cash Remaining', bVal: '—', sVal: fmt$(s.tacticalCash), bColor:'var(--blue)', sColor:'var(--amber)', winnerB: false, key:'tc' },
];

$('grid').innerHTML = cards.map(c => `
  <div class="card">
    <div class="card-accent" style="background:${c.winnerB ? 'var(--blue)' : 'var(--green)'}"></div>
    <div class="card-label">${c.label}${c.note ? '<br><span style="font-size:10px">' + c.note + '</span>' : ''}</div>
    <div class="card-row">
      <div>
        <div class="card-badge badge-b">Baseline</div>
        <div class="card-val" style="color:var(--blue)">${c.bVal}</div>
      </div>
      <div>
        <div class="card-badge badge-s">Strategy</div>
        <div class="card-val" style="color:var(--green)">${c.sVal}</div>
      </div>
    </div>
    ${c.key === 'irr' ? '<div class="card-winner">' + (c.winnerB ? '🔵' : '🟢') + ' wins</div>' : ''}
